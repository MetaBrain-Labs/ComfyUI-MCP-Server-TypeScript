{
  "name": "comfyui-mcp-server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "npx tsx ./src/index.ts",
    "dev:stdio": "npx tsx ./src/server-stdio.ts",
    "inspector": "npx @modelcontextprotocol/inspector --config ./configs/inspector/dev.json --server default-server",
    "test": "jest",
    "test:coverage": "jest --coverage --collectCoverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "type-check": "tsc --noEmit",
    "lint": "echo 'No linter configured yet. Consider adding ESLint.'",
    "check": "npm run type-check && npm run test",
    "prepare": "husky"
  },
  "keywords": [
    "mcp",
    "comfyui",
    "model-context-protocol",
    "ai-agent",
    "image-generation",
    "typescript",
    "claude",
    "cursor",
    "dify",
    "workflow",
    "stable-diffusion"
  ],
  "author": "LaiFQZzr",
  "license": "MIT",
  "description": "MCP Server that transforms ComfyUI workflows into AI-callable tools for Claude, Cursor, Dify and more",
  "lint-staged": {
    "*.{ts,tsx}": [
      "jest --findRelatedTests --passWithNoTests"
    ]
  },
  "devDependencies": {
    "@types/i18next": "^12.1.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.19.3",
    "@types/ws": "^8.18.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.4.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.24.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "axios": "^1.13.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "i18next": "^25.8.13",
    "i18next-fs-backend": "^2.6.1",
    "ws": "^8.19.0"
  }
}
